# ===== Project =====
PROJECT_NAME=telegram-socks5
PUBLIC_API_HOST=127.0.0.1
API_PORT=8088
API_BASE_URL=http://127.0.0.1:8088
SOCKS5_PORT=1080
DATA_DIR=./data

# ===== Admin bootstrap =====
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me-superadmin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-me-admin

# ===== Runtime files =====
SOCKS5_USERS_FILE=/data/users.json
SOCKS5_PROXY_CONFIG_FILE=/data/3proxy.cfg
SOCKS5_PROXY_PID_FILE=/data/3proxy.pid
SOCKS5_PROXY_LOG_FILE=/data/3proxy.log
SOCKS5_PROXY_RELOAD_REQUEST_FILE=/data/reload.request
SOCKS5_PROXY_RELOAD_STATUS_FILE=/data/reload.status
PROXY_PRIMARY_RESOLVER=1.1.1.1
PROXY_SECONDARY_RESOLVER=8.8.8.8
PROXY_RESOLVE_MODE=ipv4
PROXY_DEBUG_LOGGING=true

# ===== Security / JWT =====
JWT_SECRET=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

# ===== MTProto Proxy =====
ENABLE_MTPROTO=true
MTPROTO_PORT=443
MTPROTO_STATS_PORT=8888
MTPROTO_CLIENT_SECRET=0123456789abcdef0123456789abcdef
MTPROTO_TLS_DOMAIN=
MTPROTO_TAG=

# ===== Smoke test =====
SMOKE_TEST_URL=https://api.ipify.org?format=json
