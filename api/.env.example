# Shared data/runtime paths
SOCKS5_DATA_DIR=/data
SOCKS5_USERS_FILE=/data/users.json
SOCKS5_PROXY_CONFIG_FILE=/data/3proxy.cfg
SOCKS5_PROXY_PID_FILE=/data/3proxy.pid
SOCKS5_PROXY_LOG_FILE=/data/3proxy.log
SOCKS5_PROXY_RELOAD_REQUEST_FILE=/data/3proxy.reload

# Network ports
SOCKS5_PORT=1080
API_PORT=8000

# Superadmin credentials
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
